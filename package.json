{
  "name": "@centralnicgroup-opensource/rtldev-middleware-semantic-release-plugins",
  "version": "0.0.0-development",
  "private": false,
  "description": "CentralNic semantic-release plugin collection.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./maven": "./src/plugins/maven/index.js",
    "./notes-override": "./src/plugins/notes-override/index.js",
    "./notify": "./src/plugins/notify/index.js",
    "./replace": "./src/plugins/replace/index.js",
    "./teams-notify": "./src/plugins/notify/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/centralnicgroup-opensource/rtldev-middleware-semantic-release-plugins.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": "^22.14.0 || >=24.10.0"
  },
  "scripts": {
    "build": "find src test -name '*.js' -print0 2>/dev/null | xargs -0 -r -n1 node --check",
    "test": "node --env-file-if-exists=.env --test 'test/**/*.test.js'",
    "test:coverage": "node --env-file-if-exists=.env --test 'test/**/*.test.js' --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-exclude='test/**/*.js'",
    "test:teams": "node --env-file-if-exists=.env --test test/plugins/notify/teams-notification.integration.js",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "ci": "pnpm run build && pnpm run test:coverage && pnpm run lint"
  },
  "dependencies": {
    "@semantic-release/error": "^4.0.0",
    "execa": "^5.1.1",
    "glob": "^9.2.1",
    "micromatch": "^4.0.8",
    "replace-in-file": "^8.4.0"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5"
  }
}
